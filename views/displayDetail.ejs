 /* Page Styling */
body{
    font-family: Arial, sans-serif;
    background-color:#f5f5f5;
    margin:0;
    padding:40px;
    text-align:center;
}

/* Heading */
h2{
    color:#333;
    margin-bottom:20px;
}

/* Table Styling */
table{
    width:100%;
    margin:auto;
    border-collapse:collapse;
    background:#ffffff;
}

/* Table Header */
th{
    background-color:#56b8e2;
    color:white;
    padding:10px;
}

/* Table Cells */
td{
    padding:10px;
    border:1px solid #ddd;
}

/* Alternate Row Color */
tr:nth-child(even){
    background:#f2f2f2;
}

/* Hover Effect */
tr:hover{
    background:#e6f2ff;
}

/* Pagination Container */
.pagination{
    margin-top:20px;
    position: sticky;
    bottom: 0;
    background-color: #072f46;
}

/* Pagination Links */
.pagination a{
    display:inline-block;
    padding:8px 14px;
    margin:3px;
    border:1px solid #5f9de5;
    text-decoration:none;
    color:#4f97cb;
    border-radius:4px;
}

/* Hover Effect */
.pagination a:hover{
    background:#50afdc;
    color:white;
}

/* Active Page */
.pagination a.active{
    background:#65a8de;
    color:white;
    font-weight:bold;
}

</style>
</head>

<body>

<h2>Total applicants: <%= totalRows %></h2>
<form action="/" method="get">
</form>
<table>



    <tr>
        
        <% fields.forEach(f=>{ %>
            <th><%= f.name %></th>
       <% }) %>
    </tr>
<% basic_details.forEach(b => { %>

<tr>
<td><%= b.applicant_id %></td>
<td><%= b.first_name %></td>
<td><%= b.last_name %></td>
<td><%= b.designation%></td>
<td><%= b.email %></td>
<td><%= b.contact %></td>
<td><%= b.gender %></td>
<td><%= new Date(b.dob).toLocaleDateString('en-IN') %></td>
<td><%=b.relationship %></td>
<td><%=b.address1 %></td>
<td><%=b.address2 %></td>
<td><%=b.city %></td>
<td><%= b.state %></td>
<td><%=b.zipcode %></td>
<td><a href="/view/<%= b.applicant_id %>">View</a></td>
<td><a href="/edit/<%=b.applicant_id %>">Edit</a></td>
<td><a href="/delete/<%= b.applicant_id %>">Delete</a></td>
</tr>

<% }) %>

</table>
<%
let startPage;
let endPage;
if(currentPage <10 ){ 
  startPage=1;
  endPage = Math.min(10,totalPages)
}
else if(currentPage>totalPages -9){
  startPage = currentPage;
  endPage = totalPages;
}
else{
  startPage = currentPage;
  endPage = currentPage + 9;
} %>


<div class="pagination">

<% if(currentPage > 1){ %>
<a href="/?page=<%= currentPage-1 %>">Previous</a>
<% } %>

<% for(let i=startPage;i<=endPage;i++){ %>

<a 
href="/?page=<%= i %>"
class="<%= currentPage === i ? 'active' : '' %>"
>
<%= i %>
</a>

<% } %>

<% if(currentPage < totalPages){ %>
<a href="/?page=<%= currentPage+1 %>">Next</a>
<% } %>

</div>

</body>
</html>