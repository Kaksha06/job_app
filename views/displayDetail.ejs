body{
    font-family: Arial, sans-serif;
    background-color:#f5f5f5;
    margin:0;
    padding:0px;
    text-align:center;
}


h2{
    color:#333;
    margin-bottom:20px;
}

table{
    width:80%;
    margin:auto;
    border-collapse:collapse;
    background:#ffffff;
}


th{
    background-color:#56b8e2;
    color:white;
    padding:10px;
}

td{
    padding:10px;
    border:1px solid #ddd;
}


tr:nth-child(even){
    background:#f2f2f2;
}


tr:hover{
    background:#e6f2ff;
}


.pagination{
    margin-top:20px;
    position: sticky;
    bottom: 0;
    background-color: #072f46;
}


.pagination a{
    display:inline-block;
    padding:8px 14px;
    margin:3px;
    border:1px solid #5f9de5;
    text-decoration:none;
    color:#4f97cb;
    border-radius:4px;
}

.pagination a:hover{
    background:#50afdc;
    color:white;
}


.pagination a.active{
    background:#65a8de;
    color:white;
    font-weight:bold;
}


.header_container{
    display: flex;
    flex-direction: row-reverse;
    margin-bottom: 10px;
    margin-right: 20px;
}
.header_container button{
    padding: 10px;
  background-color: rgb(7, 47, 70);
  color: white;
  cursor: pointer;

}
.header_container button a{
   text-decoration: none;
   color: white;
}

</style>
</head>

<body>

<h2>Total applicants: <%= totalRows %></h2>
<div class="header_container">
    <button><a href="/addform"> Add applicant</a></button>
</div>
<form action="/" method="get">
</form>
<table>

    <tr>
        <% fields.forEach(f=>{ %>
            <% if(!(f.name == 'relationship' ||f.name == 'zipcode' || f.name=='address1' || f.name == 'address2')) {%>
            <th><%= f.name %></th>
            
       <% }}) %>
       <th>View</th>
        <th>Edit</th>
        <th>Delete</th>
    </tr>
<% basic_details.forEach(b => { %>

<tr>
<td><%= b.applicant_id %></td>
<td><%= b.first_name %></td>
<td><%= b.last_name %></td>
<td><%= b.designation%></td>
<td><%= b.email %></td>
<td><%= b.contact %></td>
<td><%= b.gender %></td>
<td><%= new Date(b.dob).toLocaleDateString('en-IN') %></td>
<td><%=b.city %></td>
<td><%= b.state %></td>
<td><a href="/view/<%= b.applicant_id %>">View</a></td>
<td><a href="/edit/<%=b.applicant_id %>">Edit</a></td>
<td><a href="/delete/<%= b.applicant_id %>">Delete</a></td>
</tr>

<% }) %>

</table>
<%
let startPage;
let endPage;
if(currentPage <10 ){ 
  startPage=1;
  endPage = Math.min(10,totalPages)
}
else if(currentPage>totalPages -9){
  startPage = currentPage - 9;
  endPage = totalPages;
}
else{
  startPage = currentPage -9;
  endPage = currentPage + 9;
} %>


<div class="pagination">

<% if(currentPage > 1){ %>
<a href="/?page=<%= currentPage-1 %>">Previous</a>
<% } %>

<% for(let i=startPage;i<=endPage;i++){ %>

<a 
href="/?page=<%= i %>"
class="<%= currentPage === i ? 'active' : '' %>"
>
<%= i %>
</a>

<% } %>

<% if(currentPage < totalPages){ %>
<a href="/?page=<%= currentPage+1 %>">Next</a>
<% } %>

</div>

</body>
</html>