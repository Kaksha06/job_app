    </fieldset>
    <br />

    <!-- education form -->
    <fieldset>
      <legend>Education details</legend>
       <table>
        <tr>
          <th>Course</th>
          <th>Name of board</th>
          <th>Passing Year</th>
          <th>Percentage</th>
          </tr>
          <tr>
            <td>
              <select name="education[0][ed_id]">
              <% edDetails.forEach((e) => { %>
                <% if(e.ed_name === 'SSC') {%>
  <option value="<%= e.ed_id %>"><%= e.ed_name %></option>
<% }}) %>
              </select>
            </td>
            <td>
              <input type="text" name="education[0][board_name]">
            </td>
            <td>
                <input type="text" name="education[0][pass_year]">
            </td>
            <td>
                <input type="number" name="education[0][percent]">
            </td>
          </tr>
          <tr>
             <td>
              <select name="education[1][ed_id]">
               <% edDetails.forEach((e) => { %>
               <% if(e.ed_name==='HSC'){%>
 <option value="<%= e.ed_id %>"><%= e.ed_name %></option>
<% }}) %>
              </select>
            </td>
           <td>
              <input type="text" name="education[1][board_name]">
            </td>
            <td>
                <input type="text" name="education[1][pass_year]">
            </td>
            <td>
                <input type="number" name="education[1][percent]">
            </td>
          </tr> 
          <tr>
             <td>
              <select name="education[2][ed_id]">
               <% edDetails.forEach((e) => { %>
                <% if(!(e.ed_name==='SSC' || e.ed_name==='HSC')){%>
  <option value="<%= e.ed_id %>"><%= e.ed_name %></option>
<% }}) %>
              </select>
            </td>
            <td>
              <input type="text" name="education[2][board_name]">
            </td>
            <td>
                <input type="text" name="education[2][pass_year]">
            </td>
            <td>
                <input type="number" name="education[2][percent]">
            </td>
          </tr>
           <tr>
             <td>
              <select name="education[3][ed_id]">
               <% edDetails.forEach((e) => { %>
                <% if(!(e.ed_name==='SSC' || e.ed_name==='HSC')){%>
  <option value="<%= e.ed_id %>"><%= e.ed_name %></option>
<% }}) %>
              </select>
            </td>
            <td>
              <input type="text" name="education[3][board_name]">
            </td>
            <td>
                <input type="text" name="education[3][pass_year]">
            </td>
            <td>
                <input type="number" name="education[3][percent]">
            </td>
          </tr>
       </table>
    
    </fieldset>

    <!-- work Experience -->
    <fieldset>
      <legend>Work Experience</legend>
      <!-- <form action="#"> -->
        <table id="container">
          <thead>
            <tr>
              <th>Company Name</th>
              <th>Designation</th>
              <th>From_date</th>
              <th>To_date</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><input type="text" id="cname[]" pattern="[A-Za-z ]{3,}" name="work[0][company_name]"
            title="Company name must contain at least 3 letters and only alphabets" required /></td>

              <td><input type="text" id="des[]"  pattern="[A-Za-z ]{2,}" 
            title="Designation must contain only letters" name= "work[0][designation]" required/></td>

              <td><input type="date" id="fromdt[]" required 
            title="Please select From Date" name="work[0][from_date]" /></td>

              <td><input type="date" id="todt[]" required 
            title="Please select To Date" name="work[0][to_date]"/></td>
              <td>
                <button type="button" onclick="removerow()">remove</button>
              </td>
            </tr>
          </tbody>
        </table>
        <button type= "button" onclick="addrow()" class="addbtn">Add</button>
      <!-- </form> -->
    </fieldset>

    <!-- Language -->
    <fieldset>
      <legend>Language Known</legend>
         <table id="langtable">

        <tr>
          <th>Language Name</th>
          <th>read</th>
          <th>write</th>
          <th>speak</th>
        </tr>

        <%languages.forEach((l,i)=>{%>
        <tr>
      <td>
        <%= l.language_name %>
        <input type="hidden" name="languages[<%= i %>][lang_id]" value="<%= l.lang_id %>">
        </td>

        <td>
        <input type="checkbox" name="languages[<%= i %>][read]" value="1">
        </td>

        <td>
        <input type="checkbox" name="languages[<%= i %>][write]" value="1">
        </td>

        <td>
        <input type="checkbox" name="languages[<%= i %>][speak]" value="1">
        </td>

        </tr>
        <% }) %>
    </table>
    </fieldset>

    <!-- Technologies -->
<fieldset>
  <legend>Technologies Known</legend>
    <table id="techtable">
        <tr>
          <th>Technology Name</th>
          <th>Beginner</th>
          <th>Intermediate</th>
          <th>Expert</th>
        </tr>
          <tbody>
            <tr>
      <td>
        <select name="technologies[0][tech_id]" >
          <% techDetails.forEach(t=>{ %>
          <option value="<%= t.tech_id %>"><%= t.tech_name %></option>
                    <% })%>
        </select>
        </td>
        <td>
        <input type="radio" name="technologies[0][proficiency_level]" value="beginner">
        </td>

        <td>
        <input type="radio" name="technologies[0][proficiency_level]" value="intermediate">
        </td>

        <td>
        <input type="radio" name="technologies[0][proficiency_level]" value="expert">
        </td>
        </tr></tbody>
    </table>
   <button type="button" id="techbtn" onclick="addTech()">Add Technology</button>
</fieldset>

<!-- Reference -->
<fieldset>
  <legend>Reference Contact</legend>
  <!-- <form> -->
    <table>
  
       <tr>
        <td>
          <label for="rname">Name</label>
          <td>
            <input type="text" name="rname" id="rname"  pattern="[A-Za-z ]{3,}"
          title="Name must contain only letters">
          </td>
        <td>
          <label for="rphn">Contact</label>
          <td>
          <input type="text" name="rphn" id="rphn" 
          pattern="[0-9]{10}"
          title="Contact must be a 10 digit number">
        </td>
        <td>
          <label for="rname">Relation</label>
          <td>
          <input type="text" name="rrel" id="rrel" 
          pattern="[A-Za-z ]{3,}"
          title="Relation must contain only letters">
        </td>
      </tr>
    </table>
  <!-- </form> -->
</fieldset>

<!-- Preferences -->
<fieldset>
  <legend>Preferences</legend>
  <!-- <form> -->
    <table>
      <tr>
        <td><label for="loc">Preferred Location</label></td>
        <td><select name="loc" id="loc">
        <option value="ahmedabad">Ahmedabad</option>
        <option value="pune">Pune</option>
        <option value="bangalore">Bangalore</option>
        </select></td>
        <td>
          <label for="np">Notice Period</label>
        </td>
        <td>
          <input type="text" name="np" id="np" required
            pattern="[0-9]{1,3}" 
            title="Enter notice period in days (numbers only)">
        </td>
          
        <td>
          <label for="dep" style="margin-right: 20px;">Department</label>
        </td>
        <td>
          <select name="dep" id="dep">
           <option value="Development">Development</option>
           <option value="Design">Design</option>
           <option value="Marketing">Marketing</option>
          </select>
        </td>
      </tr>
      <tr>
        <td>
          <label for="ectc">Expected CTC</label>
        </td>
        <td>
          <input type="text" name="ectc" id="ectc" required
            pattern="[0-9]{1,10}"
            title="Enter expected CTC in numbers only">
        </td>
        <td>
          <label for="cctc">Current CTC</label>
        </td>
        <td>
          <input type="text" name="cctc" id="cctc" required
            pattern="[0-9]{1,10}"
            title="Enter current CTC in numbers only">
        </td>
      </tr>
    </table>
      
</fieldset>
 <button type="submit">Submit</button>
 </form>
    <script>
    </script>
  </body>
</html>
